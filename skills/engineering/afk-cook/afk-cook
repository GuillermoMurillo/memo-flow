#!/usr/bin/env bash
#
# afk-cook — bash-loop Ralph for AFK (ready-for-agent) slices.
#
# One fresh `claude -p` invocation per GitHub issue. Each invocation starts
# with an empty context; state lives in the git tree, in CLAUDE.md, and in
# the GitHub issue body. The prompt template inlines the TDD rules.
#
# Each iteration starts with empty context, so the agent reads the spec from
# the issue body rather than from session memory. This is the whole reason
# this script is a bash for-loop and not one long-running session.
#
# Usage:
#   ./scripts/afk-cook                  # all open ready-for-agent issues
#   ./scripts/afk-cook 54 55 56 57      # explicit list
#   ./scripts/afk-cook 54               # one slice (good for first try)
#
# Optional env:
#   MAX_RETRIES — per-issue retry count if the agent doesn't emit
#                 SLICE_COMPLETE on the first try (default: 2). Set to 1 to
#                 force one-shot per slice.
#   PROMPT_FILE — override the prompt template path.
#   LABEL       — when called with no args, which label to query for
#                 (default: ready-for-agent).

set -euo pipefail

LABEL="${LABEL:-ready-for-agent}"

if [ $# -eq 0 ]; then
  echo "afk: no issues passed — querying gh for label '$LABEL'..."
  if ! command -v gh >/dev/null 2>&1; then
    echo "gh CLI not found; pass issue numbers explicitly or install gh" >&2
    exit 1
  fi
  ISSUES=$(gh issue list --label "$LABEL" --state open --json number -q '.[].number')
  if [ -z "$ISSUES" ]; then
    echo "afk: no open issues with label '$LABEL' found." >&2
    exit 0
  fi
  set -- $ISSUES
fi

# ──────────────────────────────────────────────────────────────────────
# Dependency resolution: parse "Blocked by #N" lines from issue bodies
# and topologically sort the queue so each slice runs only after its
# prerequisites have been satisfied (either closed on the tracker, or
# already completed earlier in this run).
# ──────────────────────────────────────────────────────────────────────

echo "afk: resolving dependencies for $# issue(s): $*"

# DEPS_RAW: one line per queue issue, format "<N>=<dep1> <dep2> ..."
# STATES:   one line per referenced issue, format "<N>=<STATE>" (OPEN/CLOSED)
DEPS_RAW=""
STATES=""

# Pass 1: for each input issue, fetch body+state in one gh call, parse deps.
for N in "$@"; do
  INFO=$(gh issue view "$N" --json body,state -q '"\(.state)\n\(.body)"' 2>/dev/null || echo "UNKNOWN")
  STATE=$(echo "$INFO" | head -1)
  BODY=$(echo "$INFO" | tail -n +2)
  # Extract the "## Blocked by" section, then pull any #N references out of it.
  # Matches both `#9` (informal) and `owner/repo#9` (the format /to-issues writes).
  # `|| true` swallows the non-zero grep exit when a section has "None" or no refs.
  DEPS=$(echo "$BODY" \
    | awk '/^## Blocked by/{flag=1; next} /^##/{flag=0} flag' \
    | grep -oE "#[0-9]+" \
    | grep -oE "[0-9]+" \
    | sort -un \
    | tr '\n' ' ' || true)
  DEPS_RAW="${DEPS_RAW}${N}=${DEPS}
"
  STATES="${STATES}${N}=${STATE}
"
done

# Pass 2: for any dep not already in the queue (external dep), fetch its state.
EXTERNAL=""
for N in "$@"; do
  D_LIST=$(echo "$DEPS_RAW" | grep "^$N=" | head -1 | cut -d= -f2)
  for D in $D_LIST; do
    # Skip if already in queue or already collected as external
    case " $* $EXTERNAL " in *" $D "*) continue;; esac
    EXTERNAL="$EXTERNAL $D"
  done
done
for D in $EXTERNAL; do
  STATE=$(gh issue view "$D" --json state -q .state 2>/dev/null || echo "UNKNOWN")
  STATES="${STATES}${D}=${STATE}
"
done

# Helpers
deps_of() { echo "$DEPS_RAW" | grep "^$1=" | head -1 | cut -d= -f2; }
state_of() { echo "$STATES" | grep "^$1=" | head -1 | cut -d= -f2; }

# Pass 3: topological sort (Kahn's algorithm).
# An issue is runnable when every dep is satisfied: either CLOSED on the
# tracker, or already completed in DONE_THIS_RUN.
ORDERED=""
DONE_THIS_RUN=""
REMAINING="$*"

while [ -n "$REMAINING" ]; do
  NEXT=""
  STILL_BLOCKED=""
  for N in $REMAINING; do
    BLOCKED=0
    for D in $(deps_of "$N"); do
      case " $DONE_THIS_RUN " in *" $D "*) continue;; esac
      if [ "$(state_of "$D")" != "CLOSED" ]; then
        BLOCKED=1
        break
      fi
    done
    if [ $BLOCKED -eq 0 ]; then
      NEXT="$NEXT $N"
    else
      STILL_BLOCKED="$STILL_BLOCKED $N"
    fi
  done

  if [ -z "$NEXT" ]; then
    echo "" >&2
    echo "afk: cannot proceed — dependency cycle or unsatisfiable deps:" >&2
    for N in $REMAINING; do
      DLIST=$(deps_of "$N")
      [ -z "$DLIST" ] && DLIST="(none)"
      echo "  #$N blocked by: $DLIST" >&2
    done
    exit 4
  fi

  # Within one layer, ship in numerical order for determinism.
  NEXT=$(echo "$NEXT" | tr ' ' '\n' | grep -v '^$' | sort -n | tr '\n' ' ')
  for N in $NEXT; do
    ORDERED="$ORDERED $N"
    DONE_THIS_RUN="$DONE_THIS_RUN $N"
  done
  REMAINING=$(echo "$STILL_BLOCKED" | sed 's/^ *//;s/ *$//')
done

# Reset positional args to the dep-resolved order.
set -- $ORDERED
echo "afk: dependency-ordered queue: $*"
echo ""

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPT_FILE="${PROMPT_FILE:-$SCRIPT_DIR/slice-prompt.md}"
MAX_RETRIES="${MAX_RETRIES:-2}"

if [ ! -f "$PROMPT_FILE" ]; then
  echo "missing prompt template: $PROMPT_FILE" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "claude CLI not found in PATH" >&2
  exit 1
fi

BRANCH="$(git branch --show-current)"
echo "ralph: running on branch '$BRANCH'"
echo "ralph: max retries per issue: $MAX_RETRIES"
echo ""

for N in "$@"; do
  echo "═══════════════════════════════════════════════════════════"
  echo "ralph: slice #$N"
  echo "═══════════════════════════════════════════════════════════"

  SUCCESS=0
  for ((attempt=1; attempt<=MAX_RETRIES; attempt++)); do
    echo "─── attempt $attempt of $MAX_RETRIES for #$N ───"

    # Render the prompt with the issue number substituted.
    RENDERED=$(sed "s/{{ISSUE_NUMBER}}/$N/g" "$PROMPT_FILE")

    # Fresh claude invocation. Each one starts with empty context.
    # bypassPermissions because AFK = unattended; the agent has no one to prompt
    # when it needs `gh`, `git`, or `Bash` access. Labeling work `ready-for-agent`
    # is the user's "I trust the agent, run unsupervised" signal.
    if claude --permission-mode bypassPermissions -p "$RENDERED" 2>&1 | tee /tmp/ralph-slice-${N}-${attempt}.log; then
      RESULT=$(cat /tmp/ralph-slice-${N}-${attempt}.log)
    else
      echo "─── claude invocation failed for #$N (attempt $attempt) ───" >&2
      RESULT=""
    fi

    if echo "$RESULT" | grep -q "<promise>SLICE_COMPLETE</promise>"; then
      echo ""
      echo "─── slice #$N: SLICE_COMPLETE after attempt $attempt ───"
      SUCCESS=1
      # Mark the slice done on the tracker so a subsequent afk-cook run
      # doesn't pick it up again. Comment with the new commit SHA for traceability.
      # Best-effort: failures here don't fail the slice.
      if command -v gh >/dev/null 2>&1; then
        SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
        gh issue edit "$N" --remove-label "$LABEL" >/dev/null 2>&1 || true
        if [ -n "$SHA" ]; then
          gh issue comment "$N" --body "Shipped by afk-cook in $SHA" >/dev/null 2>&1 || true
        fi
      fi
      break
    fi

    if echo "$RESULT" | grep -q "<promise>SLICE_BLOCKED:"; then
      REASON=$(echo "$RESULT" | grep "<promise>SLICE_BLOCKED:" | head -1 | sed 's/.*SLICE_BLOCKED: *//;s/<\/promise>.*//')
      echo ""
      echo "─── slice #$N: SLICE_BLOCKED — $REASON ───" >&2
      echo "─── stopping. fix the blocker and re-run. ───" >&2
      exit 2
    fi

    if [ $attempt -lt $MAX_RETRIES ]; then
      echo "─── no sentinel emitted, retrying ($attempt → $((attempt + 1))) ───" >&2
    fi
  done

  if [ $SUCCESS -eq 0 ]; then
    echo "" >&2
    echo "─── slice #$N: exhausted $MAX_RETRIES attempts without completion ───" >&2
    echo "─── inspect /tmp/ralph-slice-${N}-*.log to see what happened ───" >&2
    exit 3
  fi

  echo ""
done

echo "═══════════════════════════════════════════════════════════"
echo "ralph: all slices complete: $*"
echo "═══════════════════════════════════════════════════════════"
